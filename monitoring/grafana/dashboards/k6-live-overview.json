{
  "id": null,
  "uid": "k6-live-overview",
  "title": "k6 Live Overview",
  "tags": ["k6", "prometheus", "live"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "test_run_id",
        "label": "Test Run ID",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values({__name__=~\"k6_.*\"}, test_run_id)",
        "refresh": 2,
        "sort": 3,
        "multi": false,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Requests Rate (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_http_reqs(_total)?\", test_run_id=~\"$test_run_id\"}[1m]))",
          "legendFormat": "http_reqs/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Failed Rate (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_http_req_failed(_total)?\", test_run_id=~\"$test_run_id\"}[1m]))",
          "legendFormat": "http_failed/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Failed %",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate({__name__=~\"k6_http_req_failed(_total)?\", test_run_id=~\"$test_run_id\"}[1m])) / clamp_min(sum(rate({__name__=~\"k6_http_reqs(_total)?\", test_run_id=~\"$test_run_id\"}[1m])), 1e-9))",
          "legendFormat": "failed %"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "VUs",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "max({__name__=~\"k6_vus\", test_run_id=~\"$test_run_id\"})", "legendFormat": "vus" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "VUs Max",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "max({__name__=~\"k6_vus_max\", test_run_id=~\"$test_run_id\"})", "legendFormat": "vus_max" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Iterations Rate (iter/s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_iterations(_total)?\", test_run_id=~\"$test_run_id\"}[1m]))",
          "legendFormat": "iterations/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Checks Rate (checks/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_checks(_total)?\", test_run_id=~\"$test_run_id\"}[1m]))",
          "legendFormat": "checks/s"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Check Success %",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate({__name__=~\"k6_checks(_total)?\", test_run_id=~\"$test_run_id\", check=~\"pass|passed|true\"}[1m])) / clamp_min(sum(rate({__name__=~\"k6_checks(_total)?\", test_run_id=~\"$test_run_id\"}[1m])), 1e-9))",
          "legendFormat": "check pass %"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Data Sent (bytes/s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_data_sent(_total)?\", test_run_id=~\"$test_run_id\"}[1m]))",
          "legendFormat": "data_sent/s"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Data Received (bytes/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_data_received(_total)?\", test_run_id=~\"$test_run_id\"}[1m]))",
          "legendFormat": "data_received/s"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Req Duration Quantiles",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate({__name__=~\"k6_http_req_duration(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum by (le) (rate({__name__=~\"k6_http_req_duration(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_duration(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.99, sum by (le) (rate({__name__=~\"k6_http_req_duration(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Iteration Duration p95",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_iteration_duration(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "iter p95"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "HTTP Blocked p95",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_blocked(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "blocked p95"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP Connecting p95",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_connecting(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "connecting p95"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "HTTP TLS Handshaking p95",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 40 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_tls_handshaking(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "tls p95"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "HTTP Sending p95",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 40 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_sending(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "sending p95"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "HTTP Waiting p95",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 40 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_waiting(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "waiting p95"
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "HTTP Receiving p95",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 48 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate({__name__=~\"k6_http_req_receiving(_seconds)?_bucket\", test_run_id=~\"$test_run_id\"}[1m])))",
          "legendFormat": "receiving p95"
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "HTTP Req Duration Mean",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 48 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({__name__=~\"k6_http_req_duration(_seconds)?_sum\", test_run_id=~\"$test_run_id\"}[1m])) / clamp_min(sum(rate({__name__=~\"k6_http_req_duration(_seconds)?_count\", test_run_id=~\"$test_run_id\"}[1m])), 1e-9)",
          "legendFormat": "mean"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "All k6 Metrics (Explorer)",
      "gridPos": { "h": 8, "w": 16, "x": 16, "y": 48 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "{__name__=~\"k6_.*\", test_run_id=~\"$test_run_id\"}",
          "legendFormat": "{{__name__}}"
        }
      ]
    }
  ]
}
